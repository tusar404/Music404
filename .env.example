# Arc Music Bot Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Required Variables
# ===========================================

# Telegram API (get from https://my.telegram.org/apps)
API_ID=0
API_HASH=

# Bot Token (get from @BotFather)
BOT_TOKEN=

# Session String (generate using string generator)
STRING1=

# MongoDB URL (get from mongodb.com/cloud/atlas)
MONGO_URL=

# Owner Telegram ID
OWNER_ID=0

# Log Channel ID (starts with -100)
LOGGER_ID=0

# ===========================================
# Optional Variables
# ===========================================

# Additional Assistant Sessions
STRING2=
STRING3=
STRING4=
STRING5=

# Database Name
DB_NAME=ArcMusic

# External API (get from deadlinetech.site)
API_URL=
API_KEY=

# Media Channel for downloads
MEDIA_CHANNEL_ID=

# Duration limit in seconds (default: 5400 = 90 minutes)
DURATION_LIMIT=5400

# Default language code
LANG_CODE=en

# ===========================================
# Feature Toggles (Developer Settings)
# ===========================================

# Enable/disable thumbnails globally
THUMBNAILS_ENABLED=True

# Auto-leave inactive chats
AUTO_LEAVE=True

# Auto-leave time in seconds (default: 7200 = 2 hours)
AUTO_LEAVE_TIME=7200

# ===========================================
# Support Info
# ===========================================

SUPPORT_CHAT=@ArcUpdates
UPDATES_CHANNEL=@ArcUpdates
SOURCE_CODE=https://github.com/TeamArc/ArcMusicBot

# ===========================================
# Spotify (Optional)
# ===========================================

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===========================================
# Cookies (Optional)
# ===========================================

# Comma-separated cookie URLs
COOKIE_URLS=
